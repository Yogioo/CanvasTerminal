      "uid": "5b92bcd4-5f1c-4898-b733-f821117b500b",
      "kind": "Html",
      "data": {
        "Html": {
          "html_source": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>笔记</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    font-family: -apple-system, \"PingFang SC\", \"Microsoft YaHei\", sans-serif;\n    background: #1a1d2e;\n    color: #e0e4f0;\n    padding: 16px;\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n  h2 {\n    font-size: 16px;\n    color: #a8b4d8;\n    font-weight: 500;\n    letter-spacing: 0.5px;\n    flex-shrink: 0;\n  }\n  h2 span { color: #6b7eb0; font-size: 12px; margin-left: 8px; }\n  textarea {\n    flex: 1;\n    background: #0f1222;\n    border: 1px solid #2a2f4a;\n    border-radius: 8px;\n    color: #d8dff0;\n    font-size: 14px;\n    line-height: 1.7;\n    padding: 12px;\n    outline: none;\n    resize: none;\n    font-family: inherit;\n    transition: border-color 0.2s;\n  }\n  textarea:focus {\n    border-color: #5b7bc0;\n    box-shadow: 0 0 0 2px rgba(91,123,192,0.15);\n  }\n  textarea::placeholder { color: #3a4060; }\n  .status {\n    font-size: 12px;\n    color: #5a6a8a;\n    flex-shrink: 0;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  .status .saved { color: #6aaa7a; }\n  .status .unsaved { color: #c89a5a; }\n  .btn-row {\n    display: flex;\n    gap: 8px;\n    flex-shrink: 0;\n  }\n  .btn-row button {\n    background: #252a42;\n    border: 1px solid #363c5a;\n    color: #c8d0e8;\n    padding: 6px 14px;\n    border-radius: 6px;\n    font-size: 12px;\n    cursor: pointer;\n    transition: background 0.15s;\n  }\n  .btn-row button:hover { background: #303660; }\n  .btn-row button:active { background: #3a4270; }\n</style>\n</head>\n<body>\n\n<h2>📝 笔记 <span>自动保存</span></h2>\n\n<div class=\"btn-row\">\n  <button onclick=\"save()\">💾 立即保存</button>\n  <button onclick=\"clearNote()\">🗑️ 清空</button>\n  <button onclick=\"copyNote()\">📋 复制</button>\n</div>\n\n<textarea id=\"note\" placeholder=\"在此输入笔记内容……\" spellcheck=\"false\"></textarea>\n\n<div class=\"status\">\n  <span id=\"statusText\">就绪</span>\n  <span id=\"infoText\"></span>\n</div>\n\n<script>\nconst STORAGE_KEY = 'canvasterminal_note';\nconst textarea = document.getElementById('note');\nconst statusText = document.getElementById('statusText');\nconst infoText = document.getElementById('infoText');\n\n// --- 加载 ---\nfunction load() {\n  const saved = localStorage.getItem(STORAGE_KEY);\n  if (saved) {\n    textarea.value = saved;\n    statusText.textContent = '✅ 已恢复上次保存';\n    statusText.className = 'saved';\n  } else {\n    textarea.value = '';\n    statusText.textContent = '📝 新笔记';\n    statusText.className = '';\n  }\n  infoText.textContent = `字数: ${textarea.value.length}`;\n}\n\n// --- 保存 ---\nfunction save() {\n  localStorage.setItem(STORAGE_KEY, textarea.value);\n  statusText.textContent = '✅ 已保存';\n  statusText.className = 'saved';\n  infoText.textContent = `字数: ${textarea.value.length}`;\n}\n\n// --- 清空 ---\nfunction clearNote() {\n  if (textarea.value && !confirm('确定清空？')) return;\n  textarea.value = '';\n  localStorage.removeItem(STORAGE_KEY);\n  statusText.textContent = '🗑️ 已清空';\n  statusText.className = '';\n  infoText.textContent = '字数: 0';\n}\n\n// --- 复制 ---\nfunction copyNote() {\n  if (!textarea.value) { statusText.textContent = '⚠️ 没有内容可复制'; return; }\n  navigator.clipboard.writeText(textarea.value).then(() => {\n    statusText.textContent = '📋 已复制';\n  }).catch(() => {\n    statusText.textContent = '❌ 复制失败';\n  });\n}\n\n// --- 自动保存（输入停止 1.2 秒后）---\nlet saveTimer = null;\ntextarea.addEventListener('input', () => {\n  infoText.textContent = `字数: ${textarea.value.length}`;\n  statusText.textContent = '⏳ 未保存...';\n  statusText.className = 'unsaved';\n  clearTimeout(saveTimer);\n  saveTimer = setTimeout(save, 1200);\n});\n\n// --- 手动触发保存（Ctrl+S）---\ntextarea.addEventListener('keydown', (e) => {\n  if ((e.ctrlKey || e.metaKey) && e.key === 's') {\n    e.preventDefault();\n    save();\n  }\n});\n\n// --- 通过 localStorage 外部变化同步（同源其它页面/标签修改后自动拉取）---\nwindow.addEventListener('storage', (e) => {\n  if (e.key === STORAGE_KEY) {\n    const oldVal = textarea.value;\n    const newVal = e.newValue || '';\n    if (oldVal !== newVal) {\n      textarea.value = newVal;\n      infoText.textContent = `字数: ${textarea.value.length}`;\n      statusText.textContent = '🔄 已同步其他标签的修改';\n      statusText.className = '';\n    }\n  }\n});\n\n// 启动\nload();\n</script>\n\n</body>\n</html>\n"
        }
